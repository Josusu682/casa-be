# ──────────────────────────────────────────────
#  Fintoc – Llaves de prueba (test mode)
#  Obtenlas en: https://app.fintoc.com/developers
# ──────────────────────────────────────────────

# Secret Key del servidor (sk_test_...)
FINTOC_SECRET_KEY=sk_test_REEMPLAZA_CON_TU_LLAVE

# Public Key del frontend (pk_test_...)
FINTOC_PUBLIC_KEY=pk_test_REEMPLAZA_CON_TU_LLAVE

# Secreto del webhook (lo obtienes al configurar el endpoint en el panel)
FINTOC_WEBHOOK_SECRET=whsec_REEMPLAZA_CON_TU_SECRETO

# URL base de tu servidor (sin barra final)
BASE_URL=http://localhost:3000

# Puerto del servidor
PORT=3000

# URLs de redirección post-pago (deben apuntar al frontend Nuxt)
# En desarrollo Nuxt corre en :3001 si el puerto 3000 ya está ocupado por este servidor
SUCCESS_URL=http://localhost:3001/confirmacion-pago
CANCEL_URL=http://localhost:3001/tienda
